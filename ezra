#!/data/data/com.termux/files/usr/bin/bash

BASE="$HOME/EzraOS"
NAME_FILE="$BASE/data/user_name.txt"

BLUE='\033[1;34m'
CYAN='\033[1;36m'
WHITE='\033[1;37m'
GRAY='\033[0;37m'
RESET='\033[0m'

mkdir -p "$BASE/data"

get_user_name() {
    if [ -s "$NAME_FILE" ]; then
        cat "$NAME_FILE"
    else
        echo "User"
    fi
}

first_run_setup() {
    if [ -s "$NAME_FILE" ]; then
        return
    fi

    clear

    printf "${BLUE}EZRA OS FIRST-TIME SETUP${RESET}\n\n"
    printf "${WHITE}Welcome to EzraOS.${RESET}\n\n"

    while true; do
        read -r -p "What is your name? " entered_name

        # Remove leading and trailing spaces.
        entered_name="$(
            printf '%s' "$entered_name" |
            sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
        )"

        if [ -n "$entered_name" ]; then
            printf '%s\n' "$entered_name" > "$NAME_FILE"
            break
        fi

        echo "Please enter a valid name."
    done

    echo
    printf "${CYAN}Welcome, %s.${RESET}\n" "$entered_name"
    printf "${GRAY}EzraOS will remember your name.${RESET}\n"
    sleep 2
}

start_mode() {
    local mode="$1"
    local label="$2"
    local user_name

    user_name="$(get_user_name)"

    clear
    printf "${BLUE}Starting EzraOS${RESET}\n\n"
    printf "${WHITE}Hello, %s.${RESET}\n" "$user_name"
    printf "${WHITE}Selected mode:${RESET} ${CYAN}%s${RESET}\n" \
        "$label"
    printf "${WHITE}Preparing AI server...${RESET}\n"

    if ! "$BASE/core/server.sh" start; then
        echo
        read -r -p "Press Enter..."
        return
    fi

    clear
    python "$BASE/core/chat.py" "$mode"
}

coding_menu() {
    while true; do
        clear
        printf "${BLUE}CODING MODE${RESET}\n\n"
        echo "[1] Java"
        echo "[2] Python"
        echo "[3] SQL"
        echo "[4] Git and GitHub"
        echo "[5] Linux and Termux"
        echo "[0] Back"
        echo

        read -r -p "Select > " choice

        case "$choice" in
            1)
                start_mode java "Java Programming"
                ;;
            2)
                start_mode python "Python Programming"
                ;;
            3)
                start_mode sql "SQL Learning"
                ;;
            4)
                start_mode git "Git and GitHub"
                ;;
            5)
                start_mode linux "Linux and Termux"
                ;;
            0)
                return
                ;;
            *)
                echo "Invalid option."
                sleep 1
                ;;
        esac
    done
}

change_name() {
    local current_name
    local new_name

    current_name="$(get_user_name)"

    clear
    printf "${BLUE}CHANGE USER NAME${RESET}\n\n"
    printf "Current name: ${CYAN}%s${RESET}\n\n" "$current_name"

    read -r -p "Enter new name: " new_name

    new_name="$(
        printf '%s' "$new_name" |
        sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
    )"

    if [ -z "$new_name" ]; then
        echo "Name was not changed."
        sleep 1
        return
    fi

    printf '%s\n' "$new_name" > "$NAME_FILE"

    echo
    printf "${CYAN}Name changed to %s.${RESET}\n" "$new_name"
    sleep 2
}

settings_menu() {
    while true; do
        clear
        printf "${BLUE}SETTINGS${RESET}\n\n"
        printf "User: ${CYAN}%s${RESET}\n\n" "$(get_user_name)"

        echo "[1] Change user name"
        echo "[2] Start AI server"
        echo "[3] Stop AI server"
        echo "[4] Restart AI server"
        echo "[5] View server log"
        echo "[6] Clear all chat history"
        echo "[0] Back"
        echo

        read -r -p "Select > " choice

        case "$choice" in
            1)
                change_name
                ;;
            2)
                "$BASE/core/server.sh" start
                echo
                read -r -p "Press Enter..."
                ;;
            3)
                "$BASE/core/server.sh" stop
                echo "AI server stopped."
                sleep 1
                ;;
            4)
                "$BASE/core/server.sh" restart
                echo
                read -r -p "Press Enter..."
                ;;
            5)
                clear

                if [ -s "$BASE/logs/server.log" ]; then
                    tail -n 50 "$BASE/logs/server.log"
                else
                    echo "No server log yet."
                fi

                echo
                read -r -p "Press Enter..."
                ;;
            6)
                read -r -p "Type CLEAR to confirm: " confirm

                if [ "$confirm" = "CLEAR" ]; then
                    rm -f "$BASE/data/history/"*.json
                    echo "Chat history cleared."
                    sleep 1
                fi
                ;;
            0)
                return
                ;;
            *)
                echo "Invalid option."
                sleep 1
                ;;
        esac
    done
}

main_menu() {
    first_run_setup

    while true; do
        local user_name
        user_name="$(get_user_name)"

        clear

        printf "${BLUE}"
        cat <<'LOGO'
███████╗███████╗██████╗  █████╗
██╔════╝╚══███╔╝██╔══██╗██╔══██╗
█████╗    ███╔╝ ██████╔╝███████║
██╔══╝   ███╔╝  ██╔══██╗██╔══██║
███████╗███████╗██║  ██║██║  ██║
╚══════╝╚══════╝╚═╝  ╚═╝╚═╝  ╚═╝
LOGO
        printf "${RESET}\n"

        printf "${WHITE}Offline AI Development Environment${RESET}\n"
        printf "${BLUE}Version${RESET} : ${CYAN}2.1.0${RESET}\n"
        printf "${BLUE}User${RESET}    : ${CYAN}%s${RESET}\n" \
            "$user_name"
        printf "${BLUE}Server${RESET}  : ${CYAN}%s${RESET}\n" \
            "$("$BASE/core/server.sh" status)"
        printf "${BLUE}Memory${RESET}  : ${CYAN}%s${RESET}\n" \
            "$(free -h | awk '/Mem:/ {print $3 " / " $2}')"
        printf "${BLUE}Storage${RESET} : ${CYAN}%s free${RESET}\n" \
            "$(df -h "$HOME" | awk 'NR==2 {print $4}')"

        echo
        printf "${BLUE}--------------------------------------------${RESET}\n"
        echo "[1] General Chat"
        echo "[2] Coding Mode"
        echo "[3] Bible Study"
        echo "[4] Projects"
        echo "[5] Notes"
        echo "[6] System Information"
        echo "[7] Settings"
        echo "[0] Exit"
        printf "${BLUE}--------------------------------------------${RESET}\n"

        read -r -p "Select > " choice

        case "$choice" in
            1)
                start_mode general "General Chat"
                ;;
            2)
                coding_menu
                ;;
            3)
                start_mode bible "Bible Study"
                ;;
            4)
                "$BASE/modules/projects.sh"
                ;;
            5)
                "$BASE/modules/notes.sh"
                ;;
            6)
                "$BASE/modules/system.sh"
                ;;
            7)
                settings_menu
                ;;
            0)
                clear
                printf "${BLUE}Goodbye, %s.${RESET}\n" "$user_name"
                exit 0
                ;;
            *)
                echo "Invalid option."
                sleep 1
                ;;
        esac
    done
}

main_menu
